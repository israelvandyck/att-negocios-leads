rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidLead(data) {
      let requiredFields = ['fullName', 'email', 'phone', 'selectedPackage', 'status', 'createdAt'];
      return data.keys().hasAll(requiredFields) &&
             data.fullName is string && data.fullName.size() > 0 && data.fullName.size() <= 100 &&
             data.email is string && data.email.size() <= 100 && data.email.matches('^.+@.+$') &&
             data.phone is string && data.phone.size() >= 10 && data.phone.size() <= 20 &&
             data.selectedPackage is string && data.selectedPackage.size() <= 50 &&
             data.status == 'PENDING' &&
             data.createdAt == request.time;
    }

    match /leads/{leadId} {
      allow create: if isValidLead(incoming()) && isValidId(leadId);
      // Allow list for admin panel (simplified for this applet)
      // In a real app, you would check request.auth.token.admin == true
      allow read: if true; 
    }
  }
}
